# ─────────────────────────────────────────────────────────────────────────────
# DocuForge supports TWO authentication modes. Configure ONE of them.
# If both are set, the API key takes precedence.
# ─────────────────────────────────────────────────────────────────────────────

# ── Option A: Gemini Developer API (API key) ────────────────────────────────
# Get a key at https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=

# ── Option B: Vertex AI (GCP Service Account JSON) ──────────────────────────
# Absolute path to the service-account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=
# Optional overrides — if blank, project_id is read from the JSON and
# location defaults to us-central1.
GCP_PROJECT_ID=
GCP_LOCATION=us-central1

# ── Model ────────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-pro

# ── Misc ─────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
OUTPUT_DIR=./output

# ── Corporate TLS interception (Zscaler / proxies) ──────────────────────────
# Absolute path to a PEM file containing your corporate root CA. If set, it
# is merged with certifi's bundle and trusted by all HTTPS clients.
CUSTOM_CA_BUNDLE=
